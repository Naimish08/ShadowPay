NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://<user>:<password>@<host>/<database>?sslmode=require

JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d
SIWE_DOMAIN=localhost
SIWE_ORIGIN=http://localhost:3000

# Fileverse integration
FILEVERSE_API_KEY=replace_with_real_api_key
FILEVERSE_BASE_URL=https://api.fileverse.io
FILEVERSE_TIMEOUT_MS=15000

# Upload policy (Phase 1)
MAX_DELIVERABLE_BYTES=10485760
ALLOWED_DELIVERABLE_MIME=text/plain,text/markdown,application/pdf,application/json

# Idempotency policy (Phase 1)
# Client should send this header on upload:
#   Idempotency-Key: <stable-unique-key-per-upload-attempt>
# Server stores key per-job to prevent duplicate records on retries.
# Max recommended key length: 128 chars
MAX_IDEMPOTENCY_KEY_LENGTH=128

# HeyElsa Sepolia posting (optional, disabled by default)
HEYELSA_ONCHAIN_ENABLED=false
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/<key>
ELSA_SIGNER_PRIVATE_KEY=<hex_private_key>
ELSA_ORCHESTRATOR_ADDRESS=0x0000000000000000000000000000000000000000
ELSA_ONCHAIN_MIN_CONFIRMATIONS=1

# x402 payment proof flow
ELSA_X402_MIN_CONFIRMATIONS=1
ELSA_X402_DISPATCH_TIMEOUT_MS=15000

# Oracle settlement callback auth
ELSA_ORACLE_WEBHOOK_SECRET=replace_with_oracle_callback_secret

# Optional on-chain reputation updates (localAgentId -> on-chain agentId map)
HEYELSA_ONCHAIN_REPUTATION_ENABLED=false
ELSA_REPUTATION_ENGINE_ADDRESS=0x0000000000000000000000000000000000000000
ELSA_AGENT_ID_MAP={"local-agent-uuid":"1"}
